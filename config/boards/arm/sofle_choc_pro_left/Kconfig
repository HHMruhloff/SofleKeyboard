# Definition des Boards (was früher in Kconfig.board stand)
config BOARD_SOFLE_CHOC_PRO_LEFT
    bool "Sofle Choc Pro Left"
    depends on SOC_NRF52840_QIAA

# Setzen des Board-Namens für das System
if BOARD_SOFLE_CHOC_PRO_LEFT
config BOARD
    default "sofle_choc_pro_left"

# Hier kannst du weitere Hardware-Defaults erzwingen
config ZMK_KEYBOARD_NAME
    default "SoflePro"
endif